{
  "name": "copilotkit-vue",
  "version": "0.1.2",
  "description": "Vue 3 native bindings for CopilotKit",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": "./styles/index.css"
  },
  "files": [
    "dist",
    "styles"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && pnpm run build:dts",
    "build:dts": "vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "check-types": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.52",
    "@ag-ui/core": "^0.0.52",
    "@copilotkit/core": "^1.56.2",
    "@copilotkit/shared": "^1.56.2",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/core": "^13.1.0",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "tsdown": "^0.12.5",
    "typescript": "^5.2.3",
    "vitest": "^3.2.4",
    "vue": "^3.4.0",
    "vue-tsc": "^2.2.10"
  }
}
