{
  "name": "copilotkit-vue",
  "version": "0.1.2",
  "description": "Vue 3 native bindings for CopilotKit",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles": "./styles/index.css"
  },
  "files": [
    "dist",
    "styles"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync:styles": "node ./scripts/sync-styles.mjs",
    "check:styles": "node ./scripts/check-styles-sync.mjs",
    "build": "pnpm run sync:styles && tsdown && pnpm run build:dts",
    "build:dts": "node -e \"const fs=require('fs'); try{fs.unlinkSync('tsconfig.tsbuildinfo')}catch(e){}\" && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "tsdown --watch",
    "storybook": "storybook dev -p 6006",
    "storybook:dev": "concurrently \"pnpm run storybook:ui\" \"pnpm run storybook:runtime\" \"pnpm run storybook:agent\" --names sb,runtime,agent --prefix-colors blue,magenta,green --kill-others",
    "storybook:ui": "wait-on tcp:127.0.0.1:4000 tcp:127.0.0.1:8000 && storybook dev -p 6006",
    "storybook:runtime": "node ../../examples/basic/runtime-server.mjs",
    "storybook:agent": "node ../../examples/scripts/runner.js run-agent",
    "build-storybook": "storybook build",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "check-types": "vue-tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.52",
    "@ag-ui/core": "^0.0.52",
    "@copilotkit/core": "^1.56.2",
    "@copilotkit/shared": "^1.56.2",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/core": "^13.1.0",
    "markdown-it": "^14.1.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/vue3": "^8.6.18",
    "@storybook/vue3-vite": "^8.6.18",
    "@vue/test-utils": "^2.4.6",
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.2.1",
    "jsdom": "^24.1.3",
    "storybook": "^8.6.18",
    "tsdown": "^0.12.5",
    "typescript": "^5.2.3",
    "vite": "^6.4.1",
    "vitest": "^3.2.4",
    "vue": "^3.4.0",
    "vue-tsc": "^2.2.10",
    "wait-on": "^8.0.5"
  }
}
