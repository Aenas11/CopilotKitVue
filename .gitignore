# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
storybook-static/
**/storybook-static/
*.d.ts
*.d.cts
*.d.mts
*.tsbuildinfo

# Vue example source artifacts (generated by accidental emit)
examples/basic/src/*.js
examples/basic/src/*.js.map
examples/basic/src/*.d.ts
examples/basic/src/*.d.ts.map
!examples/basic/src/vite-env.d.ts
examples/sidebar/src/*.js
examples/sidebar/src/*.js.map
examples/sidebar/src/*.d.ts
examples/sidebar/src/*.d.ts.map
!examples/sidebar/src/vite-env.d.ts
examples/composables/src/*.js
examples/composables/src/*.js.map
examples/composables/src/*.d.ts
examples/composables/src/*.d.ts.map
!examples/composables/src/vite-env.d.ts

# Vue package source artifacts (generated by accidental emit)
packages/vue/src/**/*.js
packages/vue/src/**/*.js.map
packages/vue/src/**/*.d.ts
packages/vue/src/**/*.d.ts.map
!packages/vue/src/**/vite-env.d.ts
packages/vue/tsconfig.tsbuildinfo

# Env
.env
.env.local
.env.*.local

# Editor
.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db

# Test / coverage
coverage/
.vitest-cache/

# Logs
*.log
pnpm-debug.log*

# Turbo / Nx caches
.turbo/
.nx/cache/
examples/agent/bin-temp-verify*/*
