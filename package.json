{
  "name": "copilotkit-vue",
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter './packages/**' run build",
    "dev": "pnpm -r --filter './packages/**' run dev",
    "test": "pnpm -r --filter './packages/**' run test",
    "check-types": "pnpm -r --filter './packages/**' run check-types && pnpm --filter copilotkit-vue run check:styles",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "sync:upstream": "git submodule update --remote copilotkit-src && pnpm run sync:report",
    "sync:report": "tsx scripts/sync-react-exports.ts"
  },
  "devDependencies": {
    "@types/node": "^18.11.17",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "tsx": "^4.21.0",
    "typescript": "^5.2.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.13.1"
}
